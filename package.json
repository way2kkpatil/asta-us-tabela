{
  "name": "tabela-scanner",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "download": "tsx src/download-and-transform.ts",
    "build:client": "esbuild src/client/app.ts --bundle --format=esm --outfile=public/app.js --platform=browser",
    "build:seed": "mkdir -p public/seed && cp csv/*.csv public/seed/",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:seed && npm run build:client && npm run build:server",
    "start": "node dist/server/index.js",
    "dev": "npm run build:client && tsx watch src/server/index.ts",
    "test": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "express": "^5.1.0",
    "read-excel-file": "^9.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^26.0.1",
    "esbuild": "^0.25.9",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
